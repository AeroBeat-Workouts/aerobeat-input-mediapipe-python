# Godot 4+ specific ignores
.godot/
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# System specific
.DS_Store
Thumbs.db

# Python
__pycache__/
!python_mediapipe/__pycache__/
python_mediapipe/__pycache__/*
!python_mediapipe/__pycache__/.gdignore
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.testbed/venv/

# Unified generated desktop runtimes
!python_mediapipe/assets/runtimes/
python_mediapipe/assets/runtimes/*
!python_mediapipe/assets/runtimes/.gdignore

# Build artifacts
build/
dist/
*.tmp
test_report*.json

# MediaPipe model files are committed under python_mediapipe/assets/models/
*.task
!python_mediapipe/assets/models/*.task

# GodotEnv package workbench
.testbed/addons/*
!.testbed/addons/.editorconfig
.testbed/.addons/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Tests
.temp/
