# Godot 4+ specific ignores
.godot/
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# System specific
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.testbed/venv/

# Build artifacts
build/
dist/
*.tmp
test_report*.json

# MediaPipe model files (downloaded separately)
*.task

# GodotEnv package workbench
.testbed/addons/*
!.testbed/addons/.editorconfig
.testbed/.addons/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
